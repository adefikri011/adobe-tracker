generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              String         @id
  fullName        String?
  email           String?        @unique
  plan            String         @default("free") // "free" atau "pro"
  role            UserRole       @default(user)
  status          UserStatus     @default(active)
  
  planExpiry      DateTime?      
  
  deviceLimit     Int            @default(1)
  createdAt       DateTime       @default(now())
  assets          Asset[]
  transactions    Transaction[]
  subscriptions   Subscription[]
  loginLogs       LoginLog[]

  @@map("Profile")
}

model SearchCache {
  id        Int      @id @default(autoincrement())
  query     String
  results   Json
  createdAt DateTime @default(now())
}

model Asset {
  id            String    @id @default(cuid())
  assetId       String    @unique
  title         String
  thumbnail     String?
  downloads     Int       @default(0)
  earnings      Float     @default(0)
  keywords      String[]  @default([])
  category      String?
  fileType      String?
  uploadedAt    DateTime?
  previewUrl    String?
  assetUrl      String?
  contributor   String?
  contributorId String?
  popularity    Float     @default(0)
  profileId     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile   @relation(fields: [profileId], references: [id])
}

model UserSession {
  id             String    @id
  activeSessions Json      @default("[]")
  suspendedUntil DateTime?
  updatedAt      DateTime  @updatedAt

  @@map("UserSession")
}

// Plan yang tersedia (dikelola admin)
model Plan {
  id           String        @id @default(cuid())
  name         String        // "Pro - 7 Days"
  slug         String        @unique // "pro-7"
  description  String?
  price        Float         // harga asli
  finalPrice   Float         // harga setelah diskon
  discount     Float         @default(0) // persen diskon
  durationDays Int           // durasi dalam hari (0 = selamanya)
  features     String[]      @default([])
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  subscriptions Subscription[]
}

// Setiap transaksi pembayaran
model Transaction {
  id              String            @id @default(cuid())
  orderId         String            @unique // format: TRX-{timestamp}-{userId}
  profileId       String
  planId          String
  amount          Float
  status          TransactionStatus @default(pending)
  paymentMethod   String?           // "credit_card", "gopay", "bca_va", dll
  snapToken       String?           // token dari Midtrans Snap
  midtransOrderId String?           // order_id dari Midtrans
  paidAt          DateTime?
  expiredAt       DateTime?
  metadata        Json?             // raw response dari Midtrans
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  profile         Profile           @relation(fields: [profileId], references: [id])
  plan            Plan              @relation(fields: [planId], references: [id])
}

// Subscription aktif user
model Subscription {
  id          String             @id @default(cuid())
  profileId   String
  planId      String
  status      SubscriptionStatus @default(active)
  startDate   DateTime           @default(now())
  endDate     DateTime           // kapan expired
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  profile     Profile            @relation(fields: [profileId], references: [id])
  plan        Plan               @relation(fields: [planId], references: [id])
}

// Global App Settings (hanya 1 record)
model AppSettings {
  id              String    @id @default("singleton")
  currency        String    @default("USD")     // USD atau IDR
  exchangeRate    Float     @default(15800)     // 1 USD = X IDR
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("AppSettings")
}

// Login attempts tracking
model LoginLog {
  id        String   @id @default(cuid())
  profileId String?
  email     String
  status    String   @default("success") // "success" ou "failed"
  ipAddress String?
  device    String?  // dari User-Agent
  loginTime DateTime @default(now())
  createdAt DateTime @default(now())
  
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("LoginLog")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  suspended
}

enum TransactionStatus {
  pending
  success
  failed
  expired
  refunded
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}