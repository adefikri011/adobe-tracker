generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id            String         @id
  fullName      String?
  email         String?        @unique
  plan          String         @default("free")
  role          UserRole       @default(user)
  status        UserStatus     @default(active)
  deviceLimit   Int            @default(1)
  timezone      String         @default("Asia/Jakarta")
  timeFormat    String         @default("24h")
  createdAt     DateTime       @default(now())
  planExpiry    DateTime?
  assets        Asset[]
  loginLogs     LoginLog[]
  subscriptions Subscription[]
  syncLogs      SyncLog[]
  transactions  Transaction[]
  recentSearches RecentSearch[]

  @@map("Profile")
}

model SearchCache {
  id        Int      @id @default(autoincrement())
  query     String
  results   Json
  createdAt DateTime @default(now())
}

model MarketInsight {
  id            String   @id @default(cuid())
  query         String   // "trending", "popular", "category-xxx"
  data          Json     // Cached market data from RapidAPI
  sourceType    String   @default("rapidapi") // rapidapi, apify, etc
  lastSyncedAt  DateTime @default(now())
  expiresAt     DateTime // When this cache expires (for TTL)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([query])
  @@map("MarketInsight")
}

model Asset {
  id            String    @id @default(cuid())
  assetId       String    @unique
  title         String
  thumbnail     String?
  downloads     Int       @default(0)
  earnings      Float     @default(0)
  keywords      String[]  @default([])
  category      String?
  fileType      String?
  uploadedAt    DateTime?
  previewUrl    String?
  assetUrl      String?
  contributor   String?
  contributorId String?
  popularity    Float     @default(0)
  profileId     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile   @relation(fields: [profileId], references: [id])
}

model UserSession {
  id             String    @id
  activeSessions Json      @default("[]")
  suspendedUntil DateTime?
  updatedAt      DateTime  @updatedAt

  @@map("UserSession")
}

model Plan {
  id                      String         @id @default(cuid())
  name                    String
  slug                    String         @unique
  description             String?
  price                   Float
  finalPrice              Float
  discount                Float          @default(0)
  durationDays            Int
  deviceLimit             Int            @default(1) // Max devices for this plan
  suspendDurationMinutes  Int            @default(30) // Suspend duration if exceeding device limit
  dailySearchLimit        Int            @default(5) // Batas pencarian per hari (Free: 5, Pro: 999 for unlimited)
  maxSearches             String         @default("unlimited") // Batas hasil pencarian (5, 50, 100, 150, 200, or unlimited)
  features                String[]       @default([])
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  subscriptions           Subscription[]
  transactions            Transaction[]
}

model Transaction {
  id              String            @id @default(cuid())
  orderId         String            @unique
  profileId       String
  planId          String
  amount          Float
  status          TransactionStatus @default(pending)
  paymentMethod   String?
  snapToken       String?
  midtransOrderId String?
  paidAt          DateTime?
  expiredAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  plan            Plan              @relation(fields: [planId], references: [id])
  profile         Profile           @relation(fields: [profileId], references: [id])
}

model Subscription {
  id        String             @id @default(cuid())
  profileId String
  planId    String
  status    SubscriptionStatus @default(active)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  plan      Plan               @relation(fields: [planId], references: [id])
  profile   Profile            @relation(fields: [profileId], references: [id])
}

model AppSettings {
  id                      String   @id @default("singleton")
  currency                String   @default("USD")
  exchangeRate            Float    @default(15800)
  globalMaxDevices        Int      @default(1)      // Global device limit for all users
  suspendDurationMinutes  Int      @default(30)     // How long to suspend user when exceeding device limit
  
  // Cleanup Strategy Settings
  cleanupFrequencyDays    Int      @default(7)      // Cleanup every 1=daily, 7=weekly, 14=biweekly, 30=monthly
  minDownloadThreshold    Int      @default(5)      // Keep assets with >= this many downloads
  keepPercentage          Int      @default(70)     // Keep top 70% popular assets, delete bottom 30%
  lastCleanupAt           DateTime?                  // When was last cleanup executed
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("AppSettings")
}

model LoginLog {
  id        String   @id @default(cuid())
  profileId String?
  status    String   @default("success")
  ipAddress String? 
  createdAt DateTime @default(now())
  device    String?
  email     String
  loginTime DateTime @default(now())
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("LoginLog")
}

model SyncLog {
  id              String   @id @default(cuid())
  profileId       String
  status          String   @default("success")
  totalCollected  Int      @default(0)
  created         Int      @default(0)
  updated         Int      @default(0)
  totalInDatabase Int      @default(0)
  errorMessage    String?
  startedAt       DateTime @default(now())
  completedAt     DateTime @updatedAt
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("SyncLog")
}

model GatewayConfig {
  id             String   @id @default(cuid())
  gateway        String   @unique
  enabled        Boolean  @default(false)
  serverKey      String?
  clientKey      String?
  publishableKey String?
  mode           String   @default("sandbox")
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("GatewayConfig")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String   @unique  // Verification code 6 digits
  isUsed    Boolean  @default(false)
  expiresAt DateTime // Code expires after 15 minutes
  createdAt DateTime @default(now())

  @@map("EmailVerification")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String   @unique  // Verification code 6 digits
  isUsed    Boolean  @default(false)
  expiresAt DateTime // Code expires after 15 minutes
  createdAt DateTime @default(now())

  @@map("PasswordReset")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  suspended
}

enum TransactionStatus {
  pending
  success
  failed
  expired
  refunded
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      String
  email     String
  action    String
  detail    String
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("ActivityLog")
}

enum NotificationType {
  sale
  error
  info
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  sent      Boolean          @default(false)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  @@map("Notification")
}

model NotificationPreference {
  id                 String   @id @default("singleton")
  emailNotif         Boolean  @default(true)
  saleNotif          Boolean  @default(true)
  errorNotif         Boolean  @default(true)
  adminEmail         String   @default("admin@example.com")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("NotificationPreference")
}

model Logo {
  id            String   @id @default(cuid())
  sectionType   String   @unique // admin, user, land
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  uploadedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("Logo")
}

model Favicon {
  id            String   @id @default(cuid())
  type          String   @unique // admin, user, land
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  pageTitle     String?
  description   String?
  uploadedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("Favicon")
}

model RecentSearch {
  id        String   @id @default(cuid())
  profileId String
  query     String
  createdAt DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("RecentSearch")
}
