generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id            String         @id
  fullName      String?
  email         String?        @unique
  plan          String         @default("free")
  role          UserRole       @default(user)
  status        UserStatus     @default(active)
  deviceLimit   Int            @default(1)
  createdAt     DateTime       @default(now())
  planExpiry    DateTime?
  assets        Asset[]
  loginLogs     LoginLog[]
  subscriptions Subscription[]
  syncLogs      SyncLog[]
  transactions  Transaction[]

  @@map("Profile")
}

model SearchCache {
  id        Int      @id @default(autoincrement())
  query     String
  results   Json
  createdAt DateTime @default(now())
}

model Asset {
  id            String    @id @default(cuid())
  assetId       String    @unique
  title         String
  thumbnail     String?
  downloads     Int       @default(0)
  earnings      Float     @default(0)
  keywords      String[]  @default([])
  category      String?
  fileType      String?
  uploadedAt    DateTime?
  previewUrl    String?
  assetUrl      String?
  contributor   String?
  contributorId String?
  popularity    Float     @default(0)
  profileId     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile   @relation(fields: [profileId], references: [id])
}

model UserSession {
  id             String    @id
  activeSessions Json      @default("[]")
  suspendedUntil DateTime?
  updatedAt      DateTime  @updatedAt

  @@map("UserSession")
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Float
  finalPrice    Float
  discount      Float          @default(0)
  durationDays  Int
  deviceLimit   Int            @default(1) // Max devices for this plan
  features      String[]       @default([])
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  transactions  Transaction[]
}

model Transaction {
  id              String            @id @default(cuid())
  orderId         String            @unique
  profileId       String
  planId          String
  amount          Float
  status          TransactionStatus @default(pending)
  paymentMethod   String?
  snapToken       String?
  midtransOrderId String?
  paidAt          DateTime?
  expiredAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  plan            Plan              @relation(fields: [planId], references: [id])
  profile         Profile           @relation(fields: [profileId], references: [id])
}

model Subscription {
  id        String             @id @default(cuid())
  profileId String
  planId    String
  status    SubscriptionStatus @default(active)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  plan      Plan               @relation(fields: [planId], references: [id])
  profile   Profile            @relation(fields: [profileId], references: [id])
}

model AppSettings {
  id                      String   @id @default("singleton")
  currency                String   @default("USD")
  exchangeRate            Float    @default(15800)
  globalMaxDevices        Int      @default(1)      // Global device limit for all users
  suspendDurationMinutes  Int      @default(30)     // How long to suspend user when exceeding device limit
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("AppSettings")
}

model LoginLog {
  id        String   @id @default(cuid())
  profileId String?
  status    String   @default("success")
  ipAddress String? 
  createdAt DateTime @default(now())
  device    String?
  email     String
  loginTime DateTime @default(now())
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("LoginLog")
}

model SyncLog {
  id              String   @id @default(cuid())
  profileId       String
  status          String   @default("success")
  totalCollected  Int      @default(0)
  created         Int      @default(0)
  updated         Int      @default(0)
  totalInDatabase Int      @default(0)
  errorMessage    String?
  startedAt       DateTime @default(now())
  completedAt     DateTime @updatedAt
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("SyncLog")
}

model GatewayConfig {
  id             String   @id @default(cuid())
  gateway        String   @unique
  enabled        Boolean  @default(false)
  serverKey      String?
  clientKey      String?
  publishableKey String?
  mode           String   @default("sandbox")
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("GatewayConfig")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  suspended
}

enum TransactionStatus {
  pending
  success
  failed
  expired
  refunded
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}
