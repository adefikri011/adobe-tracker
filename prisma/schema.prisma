generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  suspended
}

model Profile {
  id        String   @id
  fullName  String?
  email     String?  @unique
  plan      String   @default("free")
  role      UserRole @default(user) 
  status    UserStatus @default(active)
  deviceLimit Int    @default(1)
  createdAt DateTime @default(now())

  @@map("Profile")
}

model SearchCache {
  id        Int      @id @default(autoincrement())
  query     String
  results   Json
  createdAt DateTime @default(now())
}

model Asset {
  id        Int      @id @default(autoincrement())
  adobeId   String   @unique
  title     String
  creator   String
  category  String   @default("")
  type      String   @default("Photo")
  downloads Int      @default(0)
  trend     String   @default("+0%")
  revenue   String   @default("$0.00")
  status    String   @default("Premium")
  createdAt DateTime @default(now())
}

model UserSession {
  id              String   @id 
  activeSessions  Json     @default("[]")  // Array of active sessions: [{token, device, createdAt}]
  suspendedUntil  DateTime? 
  updatedAt       DateTime @updatedAt

  @@map("UserSession")
}

